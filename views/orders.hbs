<h1 class="page-title">Orders</h1>

<!-- View modal -->
<div id="viewModal" class="modal-overlay" style="display:none" onclick="if(event.target===this)this.style.display='none'">
  <div class="modal" style="width:560px;max-width:calc(100vw - 40px)">
    <div class="modal-header">
      <h2 class="modal-title" id="viewModalTitle">Order #</h2>
      <button class="modal-close" onclick="document.getElementById('viewModal').style.display='none'">&times;</button>
    </div>
    <div id="viewModalBody"></div>
  </div>
</div>

<div class="card">
  {{#if orders.length}}
  <table>
    <thead>
      <tr>
        <th>#</th>
        <th>Customer</th>
        <th>Items</th>
        <th>Date</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      {{#each orders}}
      <tr>
        <td>{{this.id}}</td>
        <td>{{#if this.customer}}{{this.customer.firstName}} {{this.customer.lastName}}{{else}}—{{/if}}</td>
        <td>{{this.items.length}}</td>
        <td>{{this.createdAt}}</td>
        <td class="actions">
          <button class="btn-edit" onclick="openViewModal({{this.id}})">View</button>
        </td>
      </tr>
      {{/each}}
    </tbody>
  </table>
  {{else}}
  <div class="empty-state">No orders yet.</div>
  {{/if}}
</div>

<script>
  const ORDERS = {{{json orders}}};

  function openViewModal(id) {
    const order = ORDERS.find(function(o) { return o.id === id; });
    if (!order) return;

    document.getElementById('viewModalTitle').textContent = 'Order #' + order.id;

    const customer = order.customer
      ? order.customer.firstName + ' ' + order.customer.lastName
      : 'Guest';

    const date = new Date(order.createdAt).toLocaleString();

    const itemRows = order.items.map(function(item) {
      return '<tr><td style="padding:8px 14px;border-bottom:1px solid #f1f5f9">' + item.product.name +
             '</td><td style="padding:8px 14px;border-bottom:1px solid #f1f5f9">' + item.quantity + '</td></tr>';
    }).join('');

    document.getElementById('viewModalBody').innerHTML =
      '<p style="margin-bottom:6px;font-size:14px;color:#64748b">Customer: <strong style="color:#1e2a3a">' + customer + '</strong></p>' +
      '<p style="margin-bottom:20px;font-size:14px;color:#64748b">Date: <strong style="color:#1e2a3a">' + date + '</strong></p>' +
      '<table style="width:100%;border-collapse:collapse;font-size:14px">' +
        '<thead><tr>' +
          '<th style="text-align:left;padding:8px 14px;font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:#64748b;border-bottom:1px solid #e2e8f0">Product</th>' +
          '<th style="text-align:left;padding:8px 14px;font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:#64748b;border-bottom:1px solid #e2e8f0">Qty</th>' +
        '</tr></thead>' +
        '<tbody>' + itemRows + '</tbody>' +
      '</table>';

    document.getElementById('viewModal').style.display = 'flex';
  }
</script>
