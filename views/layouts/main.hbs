<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{title}} — E-commerce</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <div class="app-layout">
    <aside class="sidebar">
      <div class="sidebar-brand">E-commerce</div>
      <ul class="sidebar-nav">
        <li><a href="/dashboard" {{#if activeDashboard}}class="active"{{/if}}>Dashboard</a></li>
        <li><a href="/dashboard/orders" {{#if activeOrders}}class="active"{{/if}}>Orders</a></li>
        <li><a href="/dashboard/products" {{#if activeProducts}}class="active"{{/if}}>Products</a></li>
        <li><a href="/dashboard/customers" {{#if activeCustomers}}class="active"{{/if}}>Customers</a></li>
      </ul>
      <div class="sidebar-footer">
        <form method="POST" action="/auth/logout">
          <button type="submit">Sign out</button>
        </form>
      </div>
    </aside>

    <main class="main-content">
      {{{body}}}
    </main>
  </div>
</body>
</html>
