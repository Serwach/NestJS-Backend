<div class="page-header">
  <h1 class="page-title">Products</h1>
  <button class="btn-add" onclick="document.getElementById('productModal').style.display='flex'">+ Add Product</button>
</div>

<div id="productModal" class="modal-overlay" style="display:none" onclick="if(event.target===this)this.style.display='none'">
  <div class="modal">
    <div class="modal-header">
      <h2 class="modal-title">Add Product</h2>
      <button class="modal-close" onclick="document.getElementById('productModal').style.display='none'">&times;</button>
    </div>
    <form id="productForm">
      <div class="form-group">
        <label>Name</label>
        <input type="text" name="name" required placeholder="Product name" />
      </div>
      <div class="form-group">
        <label>Price ($)</label>
        <input type="number" name="price" step="0.01" min="0" required placeholder="0.00" />
      </div>
      <div class="form-group">
        <label>Description</label>
        <input type="text" name="description" placeholder="Optional description" />
      </div>
      <div class="form-group">
        <label>Image URL</label>
        <input type="url" name="imageUrl" placeholder="https://..." />
      </div>
      <button type="submit" class="btn-primary" id="saveBtn">Save Product</button>
    </form>
  </div>
</div>

<div class="card">
  {{#if products.length}}
  <table>
    <thead>
      <tr>
        <th>#</th>
        <th>Image</th>
        <th>Name</th>
        <th>Price</th>
        <th>Description</th>
      </tr>
    </thead>
    <tbody>
      {{#each products}}
      <tr>
        <td>{{this.id}}</td>
        <td>{{#if this.imageUrl}}<img src="{{this.imageUrl}}" alt="{{this.name}}" class="product-thumb" />{{else}}—{{/if}}</td>
        <td>{{this.name}}</td>
        <td>${{this.price}}</td>
        <td>{{#if this.description}}{{this.description}}{{else}}—{{/if}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>
  {{else}}
  <div class="empty-state">No products yet.</div>
  {{/if}}
</div>

<script>
  document.getElementById('productForm').addEventListener('submit', async function (e) {
    e.preventDefault();
    const data = Object.fromEntries(new FormData(e.target));
    const body = { name: data.name, price: parseFloat(data.price) };
    if (data.description) body.description = data.description;
    if (data.imageUrl) body.imageUrl = data.imageUrl;

    const btn = document.getElementById('saveBtn');
    btn.disabled = true;
    btn.textContent = 'Saving…';

    const res = await fetch('/products', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });

    if (res.ok) {
      window.location.reload();
    } else {
      btn.disabled = false;
      btn.textContent = 'Save Product';
      alert('Error saving product. Try again.');
    }
  });
</script>
